<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#1A1A1A">

<LinearLayout
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="16dp">

    <!-- FIGlet ASCII Title -->
    <TextView
        android:id="@+id/tvAsciiTitle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:fontFamily="monospace"
        android:textSize="7.5sp"
        android:textColor="#FF9800"
        android:gravity="center_horizontal"
        android:lineSpacingMultiplier="0.8"
        android:layout_marginTop="8dp"
        android:layout_marginBottom="0dp" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="v0.2.0"
        android:textSize="10sp"
        android:textColor="#555555"
        android:fontFamily="monospace"
        android:gravity="center_horizontal"
        android:layout_marginBottom="12dp" />

    <!-- Status box -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="#222222"
        android:padding="12dp"
        android:layout_marginBottom="12dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Status"
            android:textSize="12sp"
            android:textColor="#FF9800"
            android:fontFamily="monospace"
            android:textStyle="bold"
            android:layout_marginBottom="4dp" />

        <TextView
            android:id="@+id/tvStatus"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Checking..."
            android:textSize="12sp"
            android:textColor="#4CAF50"
            android:fontFamily="monospace" />
    </LinearLayout>

    <!-- Divider -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#333333"
        android:layout_marginBottom="12dp" />

    <!-- Step 1: Permissions -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="[1] Permissions"
        android:textSize="14sp"
        android:textColor="#FF9800"
        android:fontFamily="monospace"
        android:textStyle="bold"
        android:layout_marginBottom="6dp" />

    <Button
        android:id="@+id/btnAccessibility"
        android:layout_width="match_parent"
        android:layout_height="40dp"
        android:text="> Enable Accessibility Service"
        android:textSize="12sp"
        android:textColor="#4CAF50"
        android:fontFamily="monospace"
        android:background="#2A2A2A"
        android:gravity="start|center_vertical"
        android:paddingStart="12dp"
        android:layout_marginBottom="4dp"
        android:textAllCaps="false" />

    <Button
        android:id="@+id/btnOverlay"
        android:layout_width="match_parent"
        android:layout_height="40dp"
        android:text="> Enable Status Overlay"
        android:textSize="12sp"
        android:textColor="#4CAF50"
        android:fontFamily="monospace"
        android:background="#2A2A2A"
        android:gravity="start|center_vertical"
        android:paddingStart="12dp"
        android:layout_marginBottom="4dp"
        android:textAllCaps="false" />

    <Button
        android:id="@+id/btnScreenRecord"
        android:layout_width="match_parent"
        android:layout_height="40dp"
        android:text="> Grant Screen Recording"
        android:textSize="12sp"
        android:textColor="#4CAF50"
        android:fontFamily="monospace"
        android:background="#2A2A2A"
        android:gravity="start|center_vertical"
        android:paddingStart="12dp"
        android:layout_marginBottom="4dp"
        android:textAllCaps="false" />

    <TextView
        android:id="@+id/tvScreenRecordStatus"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text=""
        android:textSize="11sp"
        android:textColor="#4CAF50"
        android:fontFamily="monospace"
        android:paddingStart="12dp"
        android:layout_marginBottom="12dp" />

    <!-- Divider -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#333333"
        android:layout_marginBottom="12dp" />
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="[2] Pairing Code"
        android:textSize="14sp"
        android:textColor="#FF9800"
        android:fontFamily="monospace"
        android:textStyle="bold"
        android:layout_marginBottom="4dp" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Send to Hermes: connect my phone, code is..."
        android:textSize="11sp"
        android:textColor="#888888"
        android:fontFamily="monospace"
        android:layout_marginBottom="6dp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:background="#222222"
        android:padding="10dp"
        android:layout_marginBottom="2dp">

        <TextView
            android:id="@+id/tvPairingCode"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="------"
            android:textSize="32sp"
            android:textStyle="bold"
            android:fontFamily="monospace"
            android:textColor="#4CAF50"
            android:letterSpacing="0.4" />

        <Button
            android:id="@+id/btnRegenerate"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:text="NEW"
            android:textSize="11sp"
            android:textColor="#FF9800"
            android:fontFamily="monospace"
            android:background="#333333"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:textAllCaps="false" />
    </LinearLayout>

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="tap code to copy"
        android:textSize="10sp"
        android:textColor="#555555"
        android:fontFamily="monospace"
        android:layout_marginBottom="12dp" />

    <!-- Divider -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#333333"
        android:layout_marginBottom="12dp" />

    <!-- Step 3: Connect -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="[3] Connect to Server"
        android:textSize="14sp"
        android:textColor="#FF9800"
        android:fontFamily="monospace"
        android:textStyle="bold"
        android:layout_marginBottom="4dp" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Hermes will reply with a server address."
        android:textSize="11sp"
        android:textColor="#888888"
        android:fontFamily="monospace"
        android:layout_marginBottom="6dp" />

    <EditText
        android:id="@+id/etServerUrl"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="server-ip:8766"
        android:inputType="textUri"
        android:textSize="16sp"
        android:fontFamily="monospace"
        android:textColor="#4CAF50"
        android:textColorHint="#444444"
        android:padding="12dp"
        android:background="#222222"
        android:layout_marginBottom="6dp" />

    <TextView
        android:id="@+id/tvRelayStatus"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="[ ] not connected"
        android:textSize="12sp"
        android:textColor="#888888"
        android:fontFamily="monospace"
        android:layout_marginBottom="6dp" />

    <Button
        android:id="@+id/btnConnect"
        android:layout_width="match_parent"
        android:layout_height="44dp"
        android:text="> CONNECT"
        android:textSize="14sp"
        android:textStyle="bold"
        android:textColor="#1A1A1A"
        android:fontFamily="monospace"
        android:background="#4CAF50"
        android:layout_marginBottom="16dp"
        android:textAllCaps="false" />

    <!-- Footer -->
    <TextView
        android:id="@+id/tvAddress"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text=""
        android:textSize="10sp"
        android:fontFamily="monospace"
        android:textColor="#444444" />

    <TextView
        android:id="@+id/tvSetupCommand"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text=""
        android:textSize="0sp"
        android:visibility="gone" />

</LinearLayout>
</ScrollView>
